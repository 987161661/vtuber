# Optional deployment wiring. Omit a value to retain the local Linglan demo default.
BILIBILI_SUPERVISOR_URL=http://127.0.0.1:8197
# Browser clients normally use the Vite proxy. Set this only for a direct SSE bridge.
# VITE_BILIBILI_EVENT_ENDPOINT=http://127.0.0.1:8197
# BILIBILI_SUPERVISOR_ALLOWED_ORIGIN=http://127.0.0.1:5173
# A non-Bilibili bridge can be configured in the control room as a custom SSE
# endpoint. It emits `room-event` and `status` events with the same schema.

# Enable this content skill only where the Typhoon Boss Radar exists.
TYPHOON_CONTEXT_PATH=D:/typhoon boss radar/台风实时演进分析.md
TYPHOON_BOSS_GUIDE_PATH=D:/typhoon boss radar/boss雷达说明.md
TYPHOON_RADAR_BASE_URL=http://127.0.0.1:3038
TYPHOON_QUERY_SCRIPT=D:/LocalToolset/vtuber/aituber-onair-main/packages/core/examples/react-purupuru-app/skills/linglan-typhoon-radar/scripts/query_typhoon_radar.mjs
