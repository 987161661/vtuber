{
  "name": "@aituber-onair/soul",
  "version": "0.0.1",
  "description": "Model-agnostic causal cognition, agency, and memory protocols for AI characters.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.dev.json",
    "test": "npm run typecheck && vitest run && npm run build",
    "test:watch": "vitest",
    "fmt": "biome format . --write",
    "fmt:check": "biome format .",
    "lint": "biome lint .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "aituber",
    "vtuber",
    "agent",
    "cognition",
    "memory",
    "persona"
  ],
  "author": "shinshin86 (https://github.com/shinshin86)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shinshin86/aituber-onair.git",
    "directory": "packages/soul"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^18.15.0",
    "typescript": "^5.0.0",
    "vitest": "^1.3.1"
  },
  "browserslist": ["defaults", "not IE 11"],
  "publishConfig": {
    "access": "public"
  }
}
